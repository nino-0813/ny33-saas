GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
AI_SERVER_SECRET=

# TimesFM API（ローカルは http://127.0.0.1:8000）
TIMESFM_API_URL=http://127.0.0.1:8000
TIMESFM_API_KEY=
